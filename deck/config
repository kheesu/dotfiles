# Configuration — Sway (SwayFX) for Steam Deck
# Super-centric, mirroring the root project's Hyprland keybinds.
output * resolution 1920x1080
exec_always /home/deck/.config/sway/set-wallpaper.sh

# Border
gaps inner 5
gaps outer 5
for_window [class=".*"] border pixel 3
client.focused          #FFDF20 #FFDF20 #FFDF20 #FFDF20
client.focused_inactive #FFDF20 #FFDF20 #FFDF20 #FFDF20
client.unfocused        #BCBCBC #BCBCBC #BCBCBC #BCBCBC
client.urgent           #BCBCBC #BCBCBC #BCBCBC #BCBCBC

# SwayFX
corner_radius 12
blur enable
blur_xray enable
blur_radius 5
blur_passes 2
default_dim_inactive 0.1

# NOTE: window animations (animation_duration_ms) require SwayFX master;
# nixpkgs ships 0.5.3, which doesn't support them yet. Re-add the line once
# the packaged version includes animation support.

# ── Applications (Super + key, mirrors root hyprland.conf) ────────────────────
# Sway is launched via `nixGL sway`, which exports an LD_LIBRARY_PATH that all
# child processes inherit. That path breaks Chromium/Electron apps (brave,
# vesktop, obsidian), making them crash-loop and spawn windows endlessly, so
# those three are launched with LD_LIBRARY_PATH cleared.
bindsym Mod4+Return exec foot
bindsym Mod4+space  exec rofi -show drun -theme default
bindsym Mod4+b      exec env -u LD_LIBRARY_PATH brave --disable-gpu --ozone-platform-hint=auto
bindsym Mod4+d      exec env -u LD_LIBRARY_PATH vesktop
bindsym Mod4+o      exec env -u LD_LIBRARY_PATH obsidian
bindsym Mod4+e      exec nautilus

# ── Window controls (Super) ───────────────────────────────────────────────────
bindsym Mod4+w       kill
bindsym Mod4+f       fullscreen
bindsym Mod4+v       floating toggle
bindsym Mod4+Shift+r reload
bindsym Mod4+Shift+m exit

# ── Vim focus (Super + hjkl) ──────────────────────────────────────────────────
bindsym Mod4+h focus left
bindsym Mod4+j focus down
bindsym Mod4+k focus up
bindsym Mod4+l focus right

# ── Vim move window (Super + Shift + hjkl) ────────────────────────────────────
bindsym Mod4+Shift+h move left
bindsym Mod4+Shift+j move down
bindsym Mod4+Shift+k move up
bindsym Mod4+Shift+l move right

# ── Resize (Super + Alt + hjkl) ───────────────────────────────────────────────
bindsym Mod4+Mod1+h resize shrink width 30px
bindsym Mod4+Mod1+l resize grow width 30px
bindsym Mod4+Mod1+k resize shrink height 30px
bindsym Mod4+Mod1+j resize grow height 30px

# ── Switch workspace (Super + 1–0) ────────────────────────────────────────────
bindsym Mod4+1 workspace 1
bindsym Mod4+2 workspace 2
bindsym Mod4+3 workspace 3
bindsym Mod4+4 workspace 4
bindsym Mod4+5 workspace 5
bindsym Mod4+6 workspace 6
bindsym Mod4+7 workspace 7
bindsym Mod4+8 workspace 8
bindsym Mod4+9 workspace 9
bindsym Mod4+0 workspace 10

# ── Move window to workspace (Super + Shift + 1–0) ────────────────────────────
bindsym Mod4+Shift+1 move container to workspace 1
bindsym Mod4+Shift+2 move container to workspace 2
bindsym Mod4+Shift+3 move container to workspace 3
bindsym Mod4+Shift+4 move container to workspace 4
bindsym Mod4+Shift+5 move container to workspace 5
bindsym Mod4+Shift+6 move container to workspace 6
bindsym Mod4+Shift+7 move container to workspace 7
bindsym Mod4+Shift+8 move container to workspace 8
bindsym Mod4+Shift+9 move container to workspace 9
bindsym Mod4+Shift+0 move container to workspace 10

# ── Scratchpad (Super + S) ────────────────────────────────────────────────────
bindsym Mod4+s       scratchpad show
bindsym Mod4+Shift+s move scratchpad

# ── Cycle wallpaper (Super + Ctrl + Alt + Space — "the claw grip", per root) ──
bindsym Mod4+Ctrl+Mod1+space       exec /home/deck/.config/sway/cycle-wallpaper.sh next
bindsym Mod4+Ctrl+Mod1+Shift+space exec /home/deck/.config/sway/cycle-wallpaper.sh prev

# ── Start Waybar automatically (with the bundled config + style) ──────────────
# Two separate lines: a ';' on one exec_always line is parsed by sway as its
# own command separator (not the shell's), which would split this into a bad
# directive and Waybar would never start. pkill first so reloads don't stack.
exec_always --no-startup-id pkill waybar
exec_always --no-startup-id waybar -c /home/deck/.config/sway/waybar.config -s /home/deck/.config/sway/waybar.css
